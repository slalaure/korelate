    {
      "elementId": "Hydrochem_HvacType",
      "displayName": "Hydrochem HVAC System",
      "namespaceUri": "https://hydrochem-ag.com/uns",
      "schema": {
        "type": "object",
        "properties": {
          "temp_c": {
            "type": "number",
            "unit": "°C",
            "nominal_value": 21,
            "expected_range": [
              20.5,
              21.5
            ],
            "data_frequency_seconds": 1,
            "description": "Ambient air temperature in the cleanroom area measured in Celsius.",
            "pattern": "^(20|21|22)\\.\\d+$",
            "source": "Vaisala HMT330 Precision Temperature & Humidity Transmitter"
          },
          "humidity_rh": {
            "type": "number",
            "unit": "%",
            "nominal_value": 45,
            "expected_range": [
              40,
              50
            ],
            "data_frequency_seconds": 1,
            "description": "Relative humidity percentage in the cleanroom area.",
            "pattern": "^(4[0-9])\\.\\d+$",
            "source": "Vaisala HMT330 Precision Temperature & Humidity Transmitter"
          },
          "pressure_pa": {
            "type": "number",
            "unit": "Pa"
          },
          "ahu_vfd_hz": {
            "type": "number",
            "unit": "Hz"
          }
        }
      }
